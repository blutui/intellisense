{
  "name": "intellisense",
  "version": "0.2.0",
  "publisher": "blutui",
  "displayName": "Blutui IntelliSense",
  "description": "Intelligent tooling for Blutui's Canvas templating language in VS Code",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/blutui/intellisense.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "blutui",
    "intellisense",
    "autocomplete",
    "vscode"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.test",
        "title": "Do i work"
      }
    ],
    "languages": [
      {
        "id": "html",
        "extensions": [
          ".html",
          ".canvas"
        ],
        "aliases": [
          "html",
          "HTML"
        ],
        "configuration": "language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "html",
        "path": "./src/snippets/snippets.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/functions.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/filters.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/tests.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/auto.code-snippets"
      }
    ],
    "grammars": [
      {
        "path": "./src/syntaxes/blutui.tmLanguage.json",
        "language": "html",
        "scopeName": "text.html.canvas",
        "embeddedLanguages": {
          "source.json": "json",
          "source.css": "css",
          "source.css.scss": "scss",
          "source.js": "javascript",
          "source.ts": "typescript"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test-compile": "tsc -p ./",
    "test-watch": "tsc -watch -p ./",
    "pretest": "yarn run test-compile && yarn run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.125.0",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "prettier": "^3.9.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "overrides": {
    "loader-utils": "^3.3.1"
  }
}
