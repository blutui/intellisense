{
  "name": "intellisense",
  "version": "0.2.0",
  "publisher": "blutui",
  "displayName": "Blutui IntelliSense",
  "description": "Intelligent tooling for Blutui's Canvas templating language in VS Code",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/blutui/intellisense.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "blutui",
    "canvas",
    "syntax highlighting",
    "snippets",
    "vscode"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "html",
        "extensions": [
          ".html",
          ".canvas"
        ],
        "aliases": [
          "html",
          "HTML"
        ],
        "configuration": "language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "html",
        "path": "./src/snippets/snippets.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/functions.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/filters.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/tests.code-snippets"
      },
      {
        "language": "html",
        "path": "./src/snippets/auto.code-snippets"
      }
    ],
    "grammars": [
      {
        "path": "./src/syntaxes/blutui.tmLanguage.json",
        "language": "html",
        "scopeName": "text.html.canvas",
        "embeddedLanguages": {
          "source.json": "json",
          "source.css": "css",
          "source.css.scss": "scss",
          "source.js": "javascript",
          "source.ts": "typescript"
        }
      }
    ]
  }
}
